# S3 credentials for the PDX (non-AWS) endpoint
AWS_ACCESS_KEY_ID=<your-access-key>
AWS_SECRET_ACCESS_KEY=<your-secret-key>
AWS_DEFAULT_REGION=us-east-1
S3_ENDPOINT_URL=https://pdx.s8k.io

# VLM inference API keys — set only the one matching your chosen --endpoint
LEPTON_API_KEY=<your-lepton-api-key>        # lepton_* endpoints (default)
AZURE_OPENAI_API_KEY=<your-azure-api-key>   # azure_openai endpoint

    sha256 = "fda4ce288116b5e65d6abe5bd71724f0fe10d4ff2e5736fc21961ea09ecb5930",
    urls = ["https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2204/x86_64/libcusparselt0-cuda-12_0.8.1.1-1_amd64.deb"],
)

http_file(
    name = "libcusparselt0_dev_cuda_12_deb",
    downloaded_file_path = "libcusparselt0-dev-cuda-12.deb",
    sha256 = "b841487312c107190ac5656c880dadb7e4f02ed10ad03df483e55d7b49995cbe",

    sha256 = "275b773bd54f33438d22526f34daa908f3a7537129791430e23801d7e8ffa8ff",
    urls = ["https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2204/x86_64/libnvshmem3-cuda-12_3.3.20-1_amd64.deb"],

    name = "libnccl2_deb",
    downloaded_file_path = "libnccl2.deb",
    sha256 = "bfbad0c89f77d09406f8947f10c2ef7a2ba1b4fa2689b8772d0d85240c787315",
    urls = ["https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2204/x86_64/libnccl2_2.27.5-1+cuda12.4_amd64.deb"],
)

